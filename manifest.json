{
  "manifest_version": 3,
  "name": "Blackboard Text",
  "version": "1.0.0",
  "description": "Minimalist note-taking with customizable typography",
  "icons": {
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage"],
  "action": {
    "default_icon": {
      "48": "icons/icon-48.png"
    },
    "default_title": "Open Blackboard Text"
  },
  "background": {
    "service_worker": "service-worker.js"
  }
}
